<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>{{basics.name}} - CV</title>
    <style>
        /* Claude Theme CSS */
        body { font-family: "Georgia", serif; padding: 20px; color: #333; }
        .section-title { font-size: 1.5em; border-bottom: 1px solid #ccc; margin-top: 20px; padding-bottom: 5px; }
    </style>
</head>
<body>
    <h1>{{basics.name}}</h1>
    <p>{{basics.email}} | {{basics.phone}}</p>
    
    <div class="section-title">Summary</div>
    <div>{{{cvData.summary}}}</div>

    <div class="section-title">Experience</div>
    <div>{{{cvData.experience}}}</div>

    <div class="section-title">Education</div>
    <div>{{{cvData.education}}}</div>

    <div class="section-title">Projects</div>
    <div>{{{cvData.projects}}}</div>
</body>
</html>
