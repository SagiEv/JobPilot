<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>{{basics.name}} - CV</title>
    <style>
        /* Sales Hunter Theme CSS */
        body { font-family: "Arial", sans-serif; padding: 20px; color: #111; }
        .section-title { font-size: 1.6em; border-bottom: 2px solid #0056b3; margin-top: 20px; color: #0056b3; font-weight: bold; }
    </style>
</head>
<body>
    <h1 style="color: #0056b3; text-transform: uppercase;">{{basics.name}}</h1>
    <p>
        {{#if basics.phone}}<strong>Phone:</strong> {{basics.phone}}{{/if}}
        {{#if basics.email}} | <strong>Email:</strong> <a href="mailto:{{basics.email}}">{{basics.email}}</a>{{/if}}
        {{#if basics.linkedin}} | <strong>LinkedIn:</strong> <a href="{{basics.linkedin}}">{{basics.linkedin}}</a>{{/if}}
        {{#if basics.github}} | <strong>GitHub:</strong> <a href="{{basics.github}}">{{basics.github}}</a>{{/if}}
    </p>

    {{#if cvData.summary}}
    <div class="section-title">Summary</div>
    <div>{{{cvData.summary}}}</div>
    {{/if}}

    {{#if cvData.technicalSkills}}
    <div class="section-title">Technical Skills</div>
    <div>{{{cvData.technicalSkills}}}</div>
    {{/if}}

    {{#if cvData.education}}
    <div class="section-title">Education</div>
    <div>{{{cvData.education}}}</div>
    {{/if}}

    {{#if cvData.projects}}
    <div class="section-title">Projects</div>
    <div>{{{cvData.projects}}}</div>
    {{/if}}

    {{#if cvData.experience}}
    <div class="section-title">Experience</div>
    <div>{{{cvData.experience}}}</div>
    {{/if}}

    {{#if cvData.additionalInformation}}
    <div class="section-title">Additional Information</div>
    <div>{{{cvData.additionalInformation}}}</div>
    {{/if}}
</body>
</html>
