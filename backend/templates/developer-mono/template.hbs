<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>{{basics.name}} - CV</title>
    <style>
        /* Developer Mono Theme CSS */
        body { font-family: "Courier New", monospace; padding: 20px; background-color: #f4f4f4; color: #333; }
        .section-title { font-size: 1.4em; border-bottom: 1px dashed #333; margin-top: 20px; padding-bottom: 5px; }
        h1 { font-weight: normal; }
    </style>
</head>
<body>
    <h1>&gt; {{basics.name}}</h1>
    <p>contact: 
        {{#if basics.phone}}{{basics.phone}}{{/if}}
        {{#if basics.email}} | <a href="mailto:{{basics.email}}">{{basics.email}}</a>{{/if}}
        {{#if basics.linkedin}} | <a href="{{basics.linkedin}}">{{basics.linkedin}}</a>{{/if}}
        {{#if basics.github}} | <a href="{{basics.github}}">{{basics.github}}</a>{{/if}}
    </p>

    {{#if cvData.summary}}
    <div class="section-title">$ cat summary.txt</div>
    <div>{{{cvData.summary}}}</div>
    {{/if}}

    {{#if cvData.technicalSkills}}
    <div class="section-title">$ cat skills.json</div>
    <div>{{{cvData.technicalSkills}}}</div>
    {{/if}}

    {{#if cvData.education}}
    <div class="section-title">$ cat education.md</div>
    <div>{{{cvData.education}}}</div>
    {{/if}}

    {{#if cvData.projects}}
    <div class="section-title">$ git log projects/</div>
    <div>{{{cvData.projects}}}</div>
    {{/if}}

    {{#if cvData.experience}}
    <div class="section-title">$ ls -l experience/</div>
    <div>{{{cvData.experience}}}</div>
    {{/if}}

    {{#if cvData.additionalInformation}}
    <div class="section-title">$ cat info.txt</div>
    <div>{{{cvData.additionalInformation}}}</div>
    {{/if}}
</body>
</html>
