<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>{{basics.name}} - CV</title>
    <style>
        /* Stackoverflow Theme CSS */
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif; padding: 20px; color: #242729; }
        .section-title { font-size: 1.5em; color: #f48024; border-bottom: 1px solid #e4e6e8; margin-top: 20px; padding-bottom: 5px; }
        h1 { color: #0077cc; }
    </style>
</head>
<body>
    <h1>{{basics.name}}</h1>
    <p>{{basics.email}} | {{basics.phone}}</p>
    
    <div class="section-title">Summary</div>
    <div>{{{cvData.summary}}}</div>

    <div class="section-title">Experience</div>
    <div>{{{cvData.experience}}}</div>

    <div class="section-title">Education</div>
    <div>{{{cvData.education}}}</div>

    <div class="section-title">Projects</div>
    <div>{{{cvData.projects}}}</div>
</body>
</html>
